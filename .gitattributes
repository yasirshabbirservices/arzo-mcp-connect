# Normalize line endings — the repo stores LF; Git checks out native.
* text=auto eol=lf

*.php text eol=lf
*.css text eol=lf
*.js text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Keep development-only files out of the distributed release archive
# (`git archive` / GitHub's source zip honor export-ignore).
/.gitattributes export-ignore
/.gitignore     export-ignore
/README.md      export-ignore
